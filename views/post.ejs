
<%- include("partials/header"); -%>


    <h1><%=title%></h1>
    <p><%=content%></p>
    <a href="/posts/<%= postId %>/edit">Edit</a>

<form action="/posts/<%= postId %>/delete" method="POST" style="display:inline;">
  <button type="submit">Delete</button>
</form>

<hr>

<h3>Ask about this post 🤖</h3>

<div id="chatbox" style="border:1px solid #ccc;height:250px;overflow:auto;"></div>

<input id="msg" placeholder="Ask about this blog..." />
<button onclick="sendMessage('<%= postId %>')">Ask</button>


<script src="/chat.js"></script>


<%- include("partials/footer"); -%>
