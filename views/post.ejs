
<%- include("partials/header"); -%>

<div class="post-page" style="min-height: 100vh; padding-bottom: 200px;">    
    <h1><%=title%></h1>
    <p><%=content%></p>
   <div style="display: flex; gap: 10px; align-items: center; margin-top: 10px;">
      
      <a href="/posts/<%= postId %>/edit" class="btn edit-btn">
        Edit
      </a>

      <form action="/posts/<%= postId %>/delete" method="POST" style="margin: 0;">
        <button type="submit" class="btn btn-primary animated-button">
          Delete
        </button>
      </form>

    </div>

<hr>

<div class="chat-container" style="margin-top:20px;">
  
  <!-- Toggle Button -->
  <button onclick="toggleChat()" 
    class="btn btn-primary animated-button">
    🤖 Chat with AI
  </button>

  <!-- Dropdown Chatbox -->
  <div id="chatDropdown" style="
        display: none;
        margin-top: 10px;
        border: 1px solid #ccc;
        padding: 10px;
        border-radius: 8px;
        background: #f9f9f9;
      ">

    <div id="chatbox" style="
          max-height: 300px;
          overflow-y: auto;
          margin-bottom: 10px;
        "></div>

    <div style="display: flex; gap: 8px;">
      <input type="text" id="msg" placeholder="Ask from this post..." 
        class="form-control" style="flex: 1;" />

      <button onclick="sendMessage('<%= postId %>')" 
        class="btn btn-primary">
        Send
      </button>
    </div>

  </div>
</div>

<script src="/css/chat.js"></script>


<%- include("partials/footer"); -%>
